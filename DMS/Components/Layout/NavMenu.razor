                    <img src="/subtract.png" />
                    <span class="ABC" aria-hidden="true"></span> QCR Document
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="Retrieve">
                    <img src="/group 1171276225.png" />
                    <span class="ABC" aria-hidden="true"></span> Retrieve Documents
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="AllDocument">
                    <img src="/assignment.png" />
                    <span class="ABC" aria-hidden="true"></span> All Documents
