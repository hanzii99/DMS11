            @* <div class="nav-item px-3">
                <a class="nav-link" @onclick="ToggleUserMenu" href="#">
                    <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Settings
                    <span class="ms-1 bi @(isConfigCollapsed1 ? "bi-chevron-down" : "bi-chevron-up")"></span>
                </a>

